# Copy to .env and fill in. The server reads these via the environment.

# Your Napster Companion API key (from the Azure Portal resource / dashboard).
NAPSTER_API_KEY=

# Public URL Napster's servers can reach to call your tool endpoints.
# During a demo, expose your local server: `ngrok http 3000` or `cloudflared tunnel`.
PUBLIC_TOOL_URL=https://your-tunnel.ngrok.app

# Shared secret that gates /tools/* and /api/token. If set, the server rejects
# calls without a matching x-tool-secret header; setup-napster.js attaches it to
# the registered tools, and the operator enters it in the UI's "Operator key"
# field to drive the game. Reads (scoreboard, SSE) stay open. Use a long random
# value in production. Changing it requires re-running `npm run setup`.
TOOL_SECRET=

# Production only: the agent id to mint sessions for. Locally this is read from
# .agent.json (written by `npm run setup`); on a host where that file isn't
# deployed (e.g. Azure), set AGENT_ID explicitly instead.
# AGENT_ID=

# Voice for Buck (see Napster voice catalog). Default: alloy
VOICE_ID=alloy

# Channel: "webrtc" for the video avatar, "websocket" for voice-only.
CHANNEL=webrtc

# Local server port (default 3000).
PORT=3000
