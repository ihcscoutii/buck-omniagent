# Copy to .env and fill in. The server reads these via the environment.

# Your Napster Companion API key (from the Azure Portal resource / dashboard).
NAPSTER_API_KEY=

# Public URL Napster's servers can reach to call your tool endpoints.
# During a demo, expose your local server: `ngrok http 3000` or `cloudflared tunnel`.
PUBLIC_TOOL_URL=https://your-tunnel.ngrok.app

# Optional shared secret. If set, the server rejects tool calls without a
# matching x-tool-secret header, and setup-napster.js attaches it to the tools.
TOOL_SECRET=

# Voice for Buck (see Napster voice catalog). Default: alloy
VOICE_ID=alloy

# Channel: "webrtc" for the video avatar, "websocket" for voice-only.
CHANNEL=webrtc

# Local server port (default 3000).
PORT=3000
