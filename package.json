{
  "name": "buck-scorekeeper",
  "version": "1.0.0",
  "description": "Buck — an AI little-league baseball announcer & scorekeeper powered by the Napster Companion API.",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "start:env": "node --env-file=.env src/server.js",
    "setup": "node --env-file=.env src/setup-napster.js",
    "token": "node --env-file=.env src/connect.js",
    "test": "node --test"
  },
  "license": "MIT"
}
